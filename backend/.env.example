# Port d'écoute du backend
PORT=3000

# Connexion à PostgreSQL
# Vous pouvez utiliser DATABASE_URL OU les variables PG* ci-dessous (pas les deux).
# DATABASE_URL=postgres://sanctuaire:sanctuaire@localhost:5432/sanctuaire

PGHOST=localhost
PGPORT=5432
PGUSER=sanctuaire
PGPASSWORD=sanctuaire
PGDATABASE=sanctuaire
